# =============================================================================
# CCT MCP Server Configuration
# Creative Critical Thinking - Model Context Protocol Server
# =============================================================================

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------

# Server name identifier (used in MCP handshake)
# Default: cct-mcp-server
CCT_SERVER_NAME=cct-mcp-server

# Transport mode: "stdio" for CLI/IDE integration, "http" for API server
# Options: stdio | http
# Default: stdio
CCT_TRANSPORT=stdio

# Host address for HTTP transport (ignored in stdio mode)
# Use 0.0.0.0 to bind all interfaces, 127.0.0.1 for localhost only
# Default: 0.0.0.0
CCT_HOST=0.0.0.0

# Port number for HTTP transport (ignored in stdio mode)
# Range: 1-65535
# Default: 8000
CCT_PORT=8000

# Maximum concurrent sessions
# Range: 1-100000
# Default: 128
CCT_MAX_SESSIONS=128

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Logging level for server output
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
CCT_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database & Storage
# -----------------------------------------------------------------------------

# Path to SQLite database file for session persistence
# Relative to project root or absolute path
# Default: database/cct_memory.db
CCT_DB_PATH=database/cct_memory.db

# Path to pricing data directory (contains per-model JSON files)
# Relative to project root or absolute path
# Default: database/datasets
CCT_PRICING_PATH=database/datasets

# -----------------------------------------------------------------------------
# AI Model Configuration
# -----------------------------------------------------------------------------

# Default AI model for cognitive processing
# Must match a model ID in the pricing directory
# Examples: claude-3-5-sonnet-20240620 | gpt-4o | claude-3-opus-20240229
# Default: claude-3-5-sonnet-20240620
CCT_DEFAULT_MODEL=claude-3-5-sonnet-20240620

# -----------------------------------------------------------------------------
# User Operational Preferences (Customize for Your Needs)
# -----------------------------------------------------------------------------

# Maximum thoughts per session (limits session complexity)
# Range: 10-10000
# Default: 200
CCT_MAX_THOUGHTS=200

# Maximum content length per thought (characters)
# Range: 100-100000
# Default: 8000
CCT_MAX_CONTENT_LENGTH=8000

# Maximum context tokens for LLM (affects token usage)
# Range: 1000-128000
# Default: 4000
CCT_MAX_CONTEXT_TOKENS=4000

# Context pruning strategy
# Options: full | sliding | summarized | branch_only
# Default: summarized
CCT_CONTEXT_STRATEGY=summarized

# Golden Thinking Pattern threshold (0.0-1.0)
# Higher = stricter quality criteria
# Default: 0.9
CCT_TP_THRESHOLD=0.9

# -----------------------------------------------------------------------------
# Forex / Currency Conversion Settings
# -----------------------------------------------------------------------------

# Forex cache TTL in seconds (how long to cache exchange rates)
# Range: 60-604800 (1 minute to 7 days)
# Default: 86400 (24 hours)
CCT_FOREX_CACHE_TTL=86400

# Default USD to IDR exchange rate (fallback if API fails)
# Range: 1000-50000
# Default: 17095.0 (April 2026 baseline)
CCT_FOREX_DEFAULT_RATE=17095.0

# Forex API endpoint for live rates
# Default: Frankfurter API (free, no API key required)
CCT_FOREX_API_URL=https://api.frankfurter.app/latest?from=USD&to=IDR

# =============================================================================
# LLM Provider Configuration (Cross-Model Audit)
# =============================================================================

# Primary provider for basic operations (e.g., openai, anthropic, gemini)
CCT_LLM_PROVIDER=gemini

# API Keys for various model families
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Local / Self-Hosted Models
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Notes:
# - All paths are relative to the project root unless absolute
# - Model IDs must have corresponding JSON files in CCT_PRICING_PATH
# - Changes require server restart to take effect
# =============================================================================
